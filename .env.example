# Vercel / Next.js runtime profile
NODE_ENV=production

# ---- Required: database/runtime security ----
DATABASE_URL=postgres://USER:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
ENFORCE_SUPABASE_IN_PRODUCTION=true

# ---- Required: auth/session ----
SESSION_SECRET=replace-with-64+char-random-secret
NEXT_SESSION_COOKIE_NAME=paytec.sid
NEXT_CSRF_COOKIE_NAME=paytec.csrf
NEXT_SESSION_TTL_HOURS=24

# ---- Required: storage (Supabase, private buckets) ----
FILE_STORAGE_PROVIDER=supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_STORAGE_BUCKET_AVATARS=avatars
SUPABASE_STORAGE_BUCKET_STATEMENTS=statements
SUPABASE_STORAGE_BUCKET_HANDOUTS=handouts
SUPABASE_STORAGE_BUCKET_SHARED=shared
SUPABASE_STORAGE_BUCKET_APPROVED_RECEIPTS=approved-receipts
SUPABASE_STORAGE_BUCKET_EXPORTS=exports

# ---- Required: background jobs + cron auth ----
JOB_RUNNER_SECRET=replace-with-long-random-secret
CRON_SECRET=replace-with-long-random-secret
# Optional shared secret accepted by internal runner endpoint
GATEWAY_WEBHOOK_SECRET=

# ---- Required today: legacy bridge (until full migration off legacy proxy/jobs) ----
LEGACY_APP_URL=https://legacy-backend.example.com

# ---- Required: Paystack ----
PAYSTACK_SECRET_KEY=sk_live_xxx
PAYSTACK_PUBLIC_KEY=pk_live_xxx
PAYSTACK_WEBHOOK_SECRET=replace-with-paystack-webhook-secret
PAYSTACK_CALLBACK_URL=https://your-project.vercel.app/api/payments/paystack/callback
PAYSTACK_API_BASE_URL=https://api.paystack.co
# Optional API timeout (ms)
PAYSTACK_TIMEOUT_MS=12000

# ---- Required if payout features enabled ----
PAYOUT_ENCRYPTION_KEY=replace-with-32-byte-base64-or-hex-key
PAYOUT_DEFAULT_SHARE_BPS=10000
PAYOUT_MINIMUM_AMOUNT=1000
# Keep false on Vercel; use cron/internal jobs instead of process intervals
ENABLE_INTERVAL_WORKERS=false
PAYOUT_WORKER_INTERVAL_MS=60000

# ---- Required: payment reference + reconciliation tuning ----
PAYMENT_REFERENCE_PREFIX=PAYTEC
PAYMENT_REFERENCE_TENANT_ID=default-school
AUTO_RECONCILE_CONFIDENCE=0.9
REVIEW_RECONCILE_CONFIDENCE=0.65

# ---- Required for password-recovery email delivery ----
EMAIL_PROVIDER=smtp
PASSWORD_RESET_EMAIL_FROM=Paytec <no-reply@example.com>

# SMTP mode (required when EMAIL_PROVIDER=smtp)
SMTP_URL=
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Paytec <no-reply@example.com>
PASSWORD_RESET_SMTP_TIMEOUT_MS=10000

# Resend mode (required when EMAIL_PROVIDER=resend)
RESEND_API_KEY=
RESEND_API_BASE_URL=https://api.resend.com
PASSWORD_RESET_EMAIL_API_TIMEOUT_MS=12000

# ---- Password recovery/security controls (recommended defaults) ----
CUSTOM_PASSWORD_MIN_LENGTH=10
PASSWORD_RESET_OTP_LENGTH=6
PASSWORD_RESET_OTP_TTL_MINUTES=10
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5
PASSWORD_RESET_OTP_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_RATE_LIMIT_WINDOW_SECONDS=3600
PASSWORD_RESET_SEND_RATE_LIMIT_MAX_ATTEMPTS=5
PASSWORD_RESET_RESET_RATE_LIMIT_MAX_ATTEMPTS=10
PASSWORD_RESET_RATE_LIMIT_BLOCK_SECONDS=1800

# ---- Optional runtime paths (mainly local/dev utilities) ----
DATA_DIR=./data
DEPARTMENT_GROUPS_PATH=./data/department-groups.csv
SQLITE_DEV_PATH=./data/paytec.sqlite

# ---- Optional statement parsing integrations ----
OCR_PROVIDER=none
OCR_SPACE_API_KEY=
OCR_SPACE_ENDPOINT=https://api.ocr.space/parse/image
STATEMENT_PARSER_PROVIDER=none
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_STATEMENT_MODEL=gpt-4o-mini

# ---- Optional approved-receipt generation tuning ----
RECEIPT_TEMPLATE_HTML=./templates/approved-student-receipt.html
RECEIPT_TEMPLATE_CSS=./templates/approved-student-receipt.css
RECEIPT_OUTPUT_DIR=./outputs/receipts
RECEIPT_BROWSER_EXECUTABLE_PATH=
RECEIPT_IMMEDIATE_ON_APPROVE=true
RECEIPT_TEMPLATE_STAMP_PATH=
RECEIPT_TEMPLATE_PAYTEC_LOGO_PATH=
RECEIPT_TEMPLATE_BRAND_LOGO_PATH=

# Optional standalone script email vars
RECEIPT_EMAIL_FROM=
RECEIPT_EMAIL_SUBJECT=Your Approved Student Receipt
RECEIPT_EMAIL_BODY=
RECEIPT_EMAIL_RETRY_COUNT=3
RECEIPT_EMAIL_RETRY_DELAY_MS=1500
RECEIPT_SCHEDULE_INTERVAL_MINUTES=30
RECEIPT_DB_PATH=

# ---- Explicitly not required for Vercel Next runtime (legacy server-only) ----
# PORT=
# ADMIN_USERNAME=
# ADMIN_PASSWORD=
# STUDENT_ROSTER_PATH=
# LECTURER_ROSTER_PATH=
# TEACHER_ROSTER_PATH=
# ROSTER_PASSWORD_HASH_ROUNDS=
# RATE_LIMIT_PRUNE_INTERVAL_MS=
# MEMORY_LOG_INTERVAL_MS=
