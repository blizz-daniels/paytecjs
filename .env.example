PORT=3000
NODE_ENV=development
DATABASE_URL=
ENFORCE_SUPABASE_IN_PRODUCTION=true
DATA_DIR=./data
# local for dev, must be supabase in production
FILE_STORAGE_PROVIDER=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET_AVATARS=avatars
SUPABASE_STORAGE_BUCKET_STATEMENTS=statements
SUPABASE_STORAGE_BUCKET_HANDOUTS=handouts
SUPABASE_STORAGE_BUCKET_SHARED=shared
SUPABASE_STORAGE_BUCKET_APPROVED_RECEIPTS=approved-receipts
SUPABASE_STORAGE_BUCKET_EXPORTS=exports
SESSION_SECRET=replace-with-a-long-random-secret
NEXT_SESSION_COOKIE_NAME=paytec.sid
NEXT_CSRF_COOKIE_NAME=paytec.csrf
NEXT_SESSION_TTL_HOURS=24
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
# Roster CSV files are import inputs only. After the first bootstrap/import, auth_roster in the database is the live source of truth.
STUDENT_ROSTER_PATH=./data/students.csv
LECTURER_ROSTER_PATH=./data/teachers.csv
OCR_PROVIDER=none
OCR_SPACE_API_KEY=
OCR_SPACE_ENDPOINT=https://api.ocr.space/parse/image
STATEMENT_PARSER_PROVIDER=none
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_STATEMENT_MODEL=gpt-4o-mini
GATEWAY_WEBHOOK_SECRET=
JOB_RUNNER_SECRET=
CRON_SECRET=
LEGACY_APP_URL=http://127.0.0.1:3001
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
# Must match your deployed Next.js domain in production
PAYSTACK_CALLBACK_URL=https://your-project.vercel.app/api/payments/paystack/callback
PAYSTACK_API_BASE_URL=https://api.paystack.co
PAYMENT_REFERENCE_PREFIX=PAYTEC
PAYMENT_REFERENCE_TENANT_ID=default-school
AUTO_RECONCILE_CONFIDENCE=0.9
REVIEW_RECONCILE_CONFIDENCE=0.65
PAYOUT_ENCRYPTION_KEY=
PAYOUT_DEFAULT_SHARE_BPS=10000
PAYOUT_MINIMUM_AMOUNT=1000
PAYOUT_WORKER_INTERVAL_MS=60000
ENABLE_INTERVAL_WORKERS=false

# Approved student receipt generator
SMTP_URL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Paytec <no-reply@example.com>
EMAIL_PROVIDER=smtp
RESEND_API_KEY=
RESEND_API_BASE_URL=https://api.resend.com
CUSTOM_PASSWORD_MIN_LENGTH=10
PASSWORD_RESET_EMAIL_FROM=Paytec <no-reply@example.com>
PASSWORD_RESET_OTP_LENGTH=6
PASSWORD_RESET_OTP_TTL_MINUTES=10
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5
PASSWORD_RESET_OTP_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_SMTP_TIMEOUT_MS=10000
PASSWORD_RESET_EMAIL_API_TIMEOUT_MS=12000
PASSWORD_RESET_RATE_LIMIT_WINDOW_SECONDS=3600
PASSWORD_RESET_SEND_RATE_LIMIT_MAX_ATTEMPTS=5
PASSWORD_RESET_RESET_RATE_LIMIT_MAX_ATTEMPTS=10
PASSWORD_RESET_RATE_LIMIT_BLOCK_SECONDS=1800
RECEIPT_EMAIL_FROM=
RECEIPT_EMAIL_SUBJECT=Your Approved Student Receipt
RECEIPT_EMAIL_BODY=
RECEIPT_DB_PATH=
RECEIPT_TEMPLATE_HTML=./templates/approved-student-receipt.html
RECEIPT_TEMPLATE_CSS=./templates/approved-student-receipt.css
RECEIPT_OUTPUT_DIR=./outputs/receipts
RECEIPT_BROWSER_EXECUTABLE_PATH=
RECEIPT_EMAIL_RETRY_COUNT=3
RECEIPT_EMAIL_RETRY_DELAY_MS=1500
RECEIPT_SCHEDULE_INTERVAL_MINUTES=30
RECEIPT_IMMEDIATE_ON_APPROVE=true
