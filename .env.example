# This template is for the Vercel-hosted Next.js app only.
# Vercel sets NODE_ENV automatically. The separate legacy backend still needs its own env file.

# Required: production database for Next auth + server routes
DATABASE_URL=postgres://USER:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Required: Supabase Storage used by Next.js uploads/downloads in production
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# Required in the current migration phase: legacy bridge for unmigrated APIs and jobs
LEGACY_APP_URL=https://legacy-backend.example.com

# Required: Paystack webhook validation/replay
# Use your Paystack secret key value here if you do not maintain a separate webhook secret.
PAYSTACK_WEBHOOK_SECRET=replace-with-paystack-secret

# Required: Vercel cron authorization for /api/internal/jobs/run
CRON_SECRET=replace-with-long-random-secret

# Required if password reset email delivery must work
EMAIL_PROVIDER=smtp
PASSWORD_RESET_EMAIL_FROM=Paytec <no-reply@example.com>
# SMTP_URL=smtps://user:pass@smtp.example.com:465
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Paytec <no-reply@example.com>

# Optional: use Resend instead of SMTP
# EMAIL_PROVIDER=resend
# PASSWORD_RESET_EMAIL_FROM=Paytec <no-reply@example.com>
# RESEND_API_KEY=re_xxx

# Optional overrides
NEXT_SESSION_COOKIE_NAME=paytec.sid
NEXT_CSRF_COOKIE_NAME=paytec.csrf
NEXT_SESSION_TTL_HOURS=24
JOB_RUNNER_SECRET=
ENFORCE_SUPABASE_IN_PRODUCTION=true
SUPABASE_STORAGE_BUCKET_AVATARS=avatars
SUPABASE_STORAGE_BUCKET_STATEMENTS=statements
SUPABASE_STORAGE_BUCKET_HANDOUTS=handouts
SUPABASE_STORAGE_BUCKET_SHARED=shared
SUPABASE_STORAGE_BUCKET_APPROVED_RECEIPTS=approved-receipts
SUPABASE_STORAGE_BUCKET_EXPORTS=exports
CUSTOM_PASSWORD_MIN_LENGTH=10
PASSWORD_RESET_OTP_LENGTH=6
PASSWORD_RESET_OTP_TTL_MINUTES=10
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5
PASSWORD_RESET_OTP_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_RATE_LIMIT_WINDOW_SECONDS=3600
PASSWORD_RESET_SEND_RATE_LIMIT_MAX_ATTEMPTS=5
PASSWORD_RESET_RESET_RATE_LIMIT_MAX_ATTEMPTS=10
PASSWORD_RESET_RATE_LIMIT_BLOCK_SECONDS=1800
PASSWORD_RESET_SMTP_TIMEOUT_MS=10000
PASSWORD_RESET_EMAIL_API_TIMEOUT_MS=12000
RECEIPT_IMMEDIATE_ON_APPROVE=true
RECEIPT_BROWSER_EXECUTABLE_PATH=

# Optional Vercel-safe temp path overrides
# DATA_DIR=/tmp/paytec
# RECEIPT_OUTPUT_DIR=/tmp/paytec/receipts

# Optional local file overrides
# DEPARTMENT_GROUPS_PATH=./data/department-groups.csv
# RECEIPT_TEMPLATE_HTML=./templates/approved-student-receipt.html
# RECEIPT_TEMPLATE_CSS=./templates/approved-student-receipt.css
# RECEIPT_TEMPLATE_STAMP_PATH=
# RECEIPT_TEMPLATE_PAYTEC_LOGO_PATH=
# RECEIPT_TEMPLATE_BRAND_LOGO_PATH=
